package com.yourapp.od;

import com.yourapp.od.api.OdDetailsData;
import com.yourapp.od.provider.OdRateArray;
import com.yourapp.od.provider.ProviderOdResponse;
import org.springframework.stereotype.Service;

import java.math.BigDecimal;
import java.time.LocalDate;
import java.time.format.DateTimeFormatter;
import java.util.List;

@Service
public class OdDetailsService {

    // Prime Rate constant (percentage points)
    private static final BigDecimal PRIME_RATE = new BigDecimal("5.00");

    public OdDetailsData buildOdDetails(ProviderOdResponse provider) {
        if (provider == null || provider.getOdrateArray() == null || provider.getOdrateArray().isEmpty()) {
            return OdDetailsData.builder().build();
        }

        OdRateArray active = selectActive(provider.getOdrateArray(), provider.getCurrOdratePtr());
        if (active == null) {
            return OdDetailsData.builder().build();
        }

        BigDecimal utilized = parseAmount(provider.getOdUtilizedAmount()); // MUST be mapped from payload

        List<BigDecimal> tierRates = computeTierRates(active, PRIME_RATE);

        BigDecimal l1 = parseLimit(active.getOdlmt1());
        BigDecimal l2 = parseLimit(active.getOdlmt2());

        Tier picked = pickSingleTier(tierRates, l1, l2, utilized);

        return OdDetailsData.builder()
                .fromAmount(picked.fromAmount())
                .toAmount(picked.toAmount())
                .ratePct(picked.ratePct())
                .odType(safe(active.getOdtype()))
                .effectiveDate(parseYYYYMMDD(active.getOdrateEffdate()))
                .build();
    }

    // currOdratePtr is 1-based: "1" means first record
    private OdRateArray selectActive(List<OdRateArray> list, String currPtr) {
        if (list == null || list.isEmpty()) return null;

        try {
            int idx = Integer.parseInt(safe(currPtr)) - 1;
            if (idx >= 0 && idx < list.size()) return list.get(idx);
        } catch (Exception ignore) {}

        return list.get(0);
    }

    private List<BigDecimal> computeTierRates(OdRateArray r, BigDecimal prime) {
        String t = safe(r.getOdtype());
        BigDecimal R1 = parseRate(r.getOdrate1());
        BigDecimal R2 = parseRate(r.getOdrate2());
        BigDecimal R3 = parseRate(r.getOdrate3());

        return switch (t) {
            case "0" -> List.of(prime.add(new BigDecimal("5.00"))); // Prime + 5%
            case "1" -> List.of(R1);
            case "2" -> List.of(R1, R2);
            case "3" -> List.of(prime.add(R1));
            case "4" -> List.of(prime.add(R1), prime.add(R2));
            case "5" -> List.of(prime.add(R1), R2);
            case "6" -> List.of(prime.add(R1), prime.add(R2), prime.add(R3));
            case "7" -> List.of(prime.add(R1), prime.add(R2), R3);
            default -> List.of();
        };
    }

    // Return ONE tier only
    private Tier pickSingleTier(List<BigDecimal> rates, BigDecimal l1, BigDecimal l2, BigDecimal utilized) {
        if (rates == null || rates.isEmpty()) return new Tier(BigDecimal.ZERO, null, BigDecimal.ZERO);

        BigDecimal A = utilized == null ? BigDecimal.ZERO : utilized;

        if (rates.size() == 1) {
            return new Tier(BigDecimal.ZERO, null, rates.get(0));
        }

        if (rates.size() == 2) {
            if (l1 == null) return new Tier(BigDecimal.ZERO, null, rates.get(0)); // fallback
            return (A.compareTo(l1) < 0)
                    ? new Tier(BigDecimal.ZERO, l1, rates.get(0))
                    : new Tier(l1, null, rates.get(1));
        }

        // 3 tiers
        if (l1 == null || l2 == null) return new Tier(BigDecimal.ZERO, null, rates.get(0)); // fallback

        if (A.compareTo(l1) < 0) return new Tier(BigDecimal.ZERO, l1, rates.get(0));
        if (A.compareTo(l2) < 0) return new Tier(l1, l2, rates.get(1));
        return new Tier(l2, null, rates.get(2));
    }

    private record Tier(BigDecimal fromAmount, BigDecimal toAmount, BigDecimal ratePct) {}

    private static String safe(String s) { return s == null ? "" : s.trim(); }

    private static BigDecimal parseRate(String s) {
        String x = safe(s);
        if (x.isEmpty()) return BigDecimal.ZERO;
        return new BigDecimal(x);
    }

    private static BigDecimal parseLimit(String s) {
        String x = safe(s);
        if (x.isEmpty() || x.matches("^0+$")) return null;
        return new BigDecimal(x);
    }

    private static BigDecimal parseAmount(String s) {
        String x = safe(s);
        if (x.isEmpty() || x.matches("^0+$")) return BigDecimal.ZERO;
        return new BigDecimal(x);
    }

    private static LocalDate parseYYYYMMDD(String s) {
        String x = safe(s);
        if (x.isEmpty() || x.equals("00000000")) return null;
        try {
            return LocalDate.parse(x, DateTimeFormatter.BASIC_ISO_DATE);
        } catch (Exception e) {
            return null;
        }
    }
}




