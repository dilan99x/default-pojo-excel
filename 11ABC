import com.fasterxml.jackson.databind.JsonNode;
import com.fasterxml.jackson.databind.ObjectMapper;

import java.util.Optional;

public class ProductTypeExtractor {

    private static final ObjectMapper MAPPER = new ObjectMapper();

    public static Optional<String> findMatchingProductAsString(String jsonString, String userProductCode) throws Exception {
        String normalized = normalizeTo3Digits(userProductCode);

        JsonNode root = MAPPER.readTree(jsonString);
        JsonNode data = root.path("data");
        if (!data.isArray()) return Optional.empty();

        for (JsonNode item : data) {
            String productTypeCode = item.path("productTypeCode").asText(null);
            if (normalized.equals(productTypeCode)) {
                // compact JSON string (no pretty-print)
                return Optional.of(MAPPER.writeValueAsString(item));
            }
        }
        return Optional.empty();
    }

    private static String normalizeTo3Digits(String code) {
        if (code == null) return null;
        String trimmed = code.trim();
        if (trimmed.matches("\\d+")) {
            int val = Integer.parseInt(trimmed);
            return String.format("%03d", val);
        }
        return trimmed;
    }
}
