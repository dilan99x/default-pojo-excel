public static String filterJsonByProductTypeCode(String jsonString, String userProductCode) throws Exception {
        String normalized = normalizeTo3Digits(userProductCode);

        JsonNode rootNode = MAPPER.readTree(jsonString);
        if (!(rootNode instanceof ObjectNode root)) {
            throw new IllegalArgumentException("Invalid JSON: root is not an object");
        }

        JsonNode dataNode = root.get("data");
        if (dataNode == null || !dataNode.isArray()) {
            throw new IllegalArgumentException("Invalid JSON: 'data' is missing or not an array");
        }

        // find match
        JsonNode matched = null;
        for (JsonNode item : dataNode) {
            String productTypeCode = item.path("productTypeCode").asText(null);
            if (normalized.equals(productTypeCode)) {
                matched = item;
                break; // keep first match
            }
        }

        if (matched == null) {
            throw new IllegalArgumentException("No match found for productTypeCode=" + normalized);
        }

        // Replace data[] with a single-element array containing the match
        ArrayNode newData = MAPPER.createArrayNode();
        newData.add(matched);
        root.set("data", newData);

        // Return full JSON as string (use pretty printer if you want)
        return MAPPER.writerWithDefaultPrettyPrinter().writeValueAsString(root);
    }
